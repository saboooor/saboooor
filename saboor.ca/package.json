{
  "name": "saboor-ca",
  "homepage": "https://saboor.ca",
  "description": "sab's portfolio",
  "engines": {
    "node": ">=23.11.0"
  },
  "type": "module",
  "author": "saboooor",
  "scripts": {
    "build": "qwik build",
    "build.client": "vite build",
    "build.preview": "vite build --ssr src/entry.preview.tsx",
    "build.server": "qwik check-client src dist && vite build -c adapters/cloudflare-pages/vite.config.ts",
    "build.types": "tsc --noEmit",
    "cf-typegen": "wrangler types",
    "deploy": "wrangler deploy",
    "fmt": "prettier --write .",
    "fmt.check": "prettier --check .",
    "lint": "eslint \"src/**/*.ts*\"",
    "preview": "qwik build preview && vite preview",
    "serve": "wrangler dev",
    "start": "vite --mode ssr --host",
    "start.debug": "node --inspect-brk ./node_modules/vite/bin/vite.js --mode ssr --forcenode --inspect-brk ./node_modules/vite/bin/vite.js --mode ssr --force",
    "qwik": "qwik"
  },
  "sideEffects": false,
  "devDependencies": {
    "@anuragroy/tailwindcss-animate": "^1.0.6",
    "@cloudflare/workers-types": "^4.20260405.1",
    "@eslint/js": "^10.0.1",
    "@luminescent/icons-qwik": "0.1.1",
    "@luminescent/ui": "^6.8.2",
    "@luminescent/ui-qwik": "7.0.0-0",
    "@qwik.dev/core": "2.0.0-beta.31",
    "@qwik.dev/router": "2.0.0-beta.31",
    "@tailwindcss/vite": "^4.2.2",
    "@types/eslint": "^9.6.1",
    "@types/node": "^25.5.2",
    "eslint": "^10.2.0",
    "eslint-plugin-qwik": "2.0.0-beta.29",
    "globals": "^17.4.0",
    "lucide-icons-qwik": "1.7.0-qwik-v2",
    "playwright": "^1.59.1",
    "simple-icons-qwik": "16.12.0-qwik-v2",
    "tailwindcss": "^4.2.2",
    "ts-morph": "^27.0.2",
    "typescript": "6.0.2",
    "typescript-eslint": "^8.58.0",
    "undici": "^8.0.2",
    "vite": "7.3.1",
    "vite-tsconfig-paths": "^6.1.1",
    "wrangler": "^4.81.0"
  }
}
